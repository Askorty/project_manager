<div class="container mx-auto p-4 md:p-8 max-w-6xl">
  <div class="flex flex-col sm:flex-row justify-between items-center mb-8 gap-4 border-b border-base-200 pb-4">
    <h1 class="text-4xl font-bold text-base-content flex items-center gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
      Мои проекты
    </h1>
    <%= link_to new_project_path, class: 'btn btn-primary shadow-lg hover:scale-105 transition-transform gap-2' do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
      Создать проект
    <% end %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% if @projects.any? %>
      <% @projects.each do |project| %>
        
        <div class="card bg-base-100 shadow-xl border border-base-200 hover:-translate-y-1 transition-all duration-300">
          <div class="card-body p-6">
            <h2 class="card-title text-xl mb-2">
              <%= link_to project.title, project, class: "link link-hover text-primary" %>
            </h2>
            <p class="text-base-content/70 grow text-sm"><%= project.description %></p>
            
            <div class="flex gap-2 mt-4 mb-2">
               <div class="badge badge-neutral badge-sm"><%= project.tasks.count %> задач</div>
            </div>

            <div class="card-actions justify-end mt-2 pt-4 border-t border-base-200">
              
              <%= link_to project, class: 'btn btn-sm btn-ghost gap-1' do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                Управление
              <% end %>

              <%= button_to project, method: :delete, data: { turbo_confirm: 'Точно удалить проект и все его задачи?' }, class: 'btn btn-sm btn-outline btn-error gap-1 px-2' do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
              <% end %>
            </div>
          </div>
        </div>

      <% end %>
    <% else %>
      <div class="col-span-full flex flex-col items-center justify-center p-12 bg-base-200 rounded-box border border-base-300 border-dashed">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-20 w-20 text-base-content/20 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9a2 2 0 00-2 2v5a2 2 0 01-2 2z" /></svg>
        <h3 class="text-xl font-bold text-base-content/70">Проектов пока нет</h3>
        <p class="text-base-content/50 mb-4">Самое время создать свой первый проект!</p>
      </div>
    <% end %>
  </div>
</div>