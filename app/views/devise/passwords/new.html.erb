<div class="flex justify-center items-center min-h-[75vh]">
  <div class="card w-full max-w-md shadow-2xl bg-base-100 border border-base-200">
    <div class="card-body p-8">
      
      <div class="flex justify-center mb-4">
        <!-- Иконка ключа -->
        <div class="bg-warning/10 p-4 rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-warning" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" /></svg>
        </div>
      </div>

      <h2 class="card-title text-2xl font-bold justify-center mb-2 text-base-content text-center">Забыли пароль?</h2>
      <p class="text-center text-sm text-base-content/70 mb-6">Введите свой email, и мы вышлем инструкции по восстановлению.</p>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "flex flex-col gap-4" }) do |f| %>
        
        <!-- Вывод ошибок (если, например, email не найден в базе) -->
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="form-control">
          <%= f.label :email, "Email", class: "label label-text font-bold" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered w-full", placeholder: "your@email.com" %>
        </div>

        <div class="form-control mt-4">
          <%= f.submit "Отправить инструкции", class: "btn btn-warning w-full text-lg shadow-md" %>
        </div>
      <% end %>

      <div class="divider text-base-content/40 mt-6">вспомнили пароль?</div>
      
      <div class="flex flex-col gap-2 text-center mt-2 text-sm">
        <%= render "devise/shared/links" %>
      </div>

    </div>
  </div>
</div>