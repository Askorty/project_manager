<div class="flex flex-col gap-2 w-full">
  
  <%- if controller_name != 'sessions' %>
    <%= link_to "Войти в существующий аккаунт", new_session_path(resource_name), class: "btn btn-outline btn-sm w-full" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Регистрация нового аккаунта", new_registration_path(resource_name), class: "btn btn-outline btn-secondary btn-sm w-full" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Забыли пароль?", new_password_path(resource_name), class: "btn btn-ghost btn-sm w-full text-base-content/70 hover:text-primary" %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "Не получили письмо подтверждения?", new_confirmation_path(resource_name), class: "link link-hover text-sm text-base-content/60" %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to "Не получили инструкции для разблокировки?", new_unlock_path(resource_name), class: "link link-hover text-sm text-base-content/60" %>
  <% end %>
  
</div>